{
  "info": {
    "name": "Orbit API",
    "description": "Collection for Orbit Social API endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5076"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register - Success with profile picture",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test(\"Response has user data\", function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.isSuccess).to.eql(true);",
                  "    pm.expect(json.data).to.have.property('id');",
                  "    pm.expect(json.data.email).to.eql('john@example.com');",
                  "    pm.expect(json.data.username).to.eql('johndoe');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "email",
                  "value": "john@example.com"
                },
                {
                  "key": "username",
                  "value": "johndoe"
                },
                {
                  "key": "displayName",
                  "value": "John Doe"
                },
                {
                  "key": "password",
                  "value": "Password123"
                },
                {
                  "key": "bio",
                  "value": "Software developer and coffee enthusiast"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
